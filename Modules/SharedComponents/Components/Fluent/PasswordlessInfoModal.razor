@using snowcoreBlog.Frontend.Core.Resources
@using snowcoreBlog.Frontend.SharedComponents.Components.Fluent
@using snowcoreBlog.Frontend.SharedComponents.Resources.Icons
@using snowcoreBlog.Frontend.SharedComponents.Services

@inject OverlayService OverlayService

<FluentLabel>
    <FluentAnchor Appearance="Appearance.Hypertext" Href="javascript: void(0);" OnClick="Show">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="0"
            VerticalGap="0" VerticalAlignment="VerticalAlignment.Center">
            <FluentRandomIdIcon Width="24px" Value="@(new QuestionIcon())" />
            <FluentSpacer Width="5" />
            @TranslationResources.PasswordlessDialogHyperlinkLabel
        </FluentStack>
    </FluentAnchor>
</FluentLabel>

<!-- The modal content is rendered globally by GlobalOverlay. Use OverlayService to show the content at root. -->

@code {
    private void Show()
    {
        var fragment = (RenderFragment)(builder =>
        {
            builder.OpenComponent(0, typeof(PasswordlessInfoModalContent));
            builder.AddAttribute(1, "OnClose", EventCallback.Factory.Create(this, (Action)(() => OverlayService.Hide())));
            builder.CloseComponent();
        });

        OverlayService.Show(fragment);
    }

    private void Hide()
    {
        OverlayService.Hide();
    }
}
