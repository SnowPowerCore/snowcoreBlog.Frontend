@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using snowcoreBlog.Frontend.Core.Resources
@using snowcoreBlog.Frontend.SharedComponents.Components.Fluent

@inherits Microsoft.AspNetCore.Components.ComponentBase

<FloatingCard Style="max-width:520px; width:100%;">
    <FluentStack Orientation="Orientation.Vertical" Class="p-3">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
            <div style="width:48px; height:48px; display:flex; align-items:center; justify-content:center; background:#eef6ff; border-radius:8px;">
                <FluentIcon Value="@(new Icons.Color.Size24.Vault())" Width="28px" />
            </div>

            <FluentStack Orientation="Orientation.Vertical" Class="ms-2">
                <FluentLabel Style="font-weight:600; font-size:1.05rem;">Passwordless sign-in</FluentLabel>
                <FluentLabel Style="color:#666; font-size:0.9rem;">Quick, safer access — no passwords required.</FluentLabel>
            </FluentStack>

            <FluentSpacer />

            <FluentButton Appearance="Appearance.Lightweight" OnClick="Close">✖</FluentButton>
        </FluentStack>

        <FluentStack Orientation="Orientation.Vertical" Class="mt-2">
            <FluentLabel>We use secure methods like passkeys and one‑time codes to sign you in — this replaces traditional passwords.</FluentLabel>
            <FluentLabel>Benefits include:</FluentLabel>
            <ul>
                <li>Faster sign-in (no password to remember) 🚀</li>
                <li>Stronger protection against phishing and reused-password attacks 🔒</li>
                <li>Works with device authenticators (built-in or external) 🔑</li>
            </ul>
            <FluentLabel Class="mt-1">If you prefer other options, check the <em>Other</em> tab for social sign-ins.</FluentLabel>
        </FluentStack>
    </FluentStack>
</FloatingCard>

@code {
    [Microsoft.AspNetCore.Components.Parameter]
    public EventCallback OnClose { get; set; }

    private Task Close() => OnClose.HasDelegate ? OnClose.InvokeAsync(null) : Task.CompletedTask;
}
